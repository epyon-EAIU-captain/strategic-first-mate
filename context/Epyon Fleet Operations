<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Epyon Operations Dashboard</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
body { font-family: 'Inter', sans-serif; background-color: #fafaf9; color: #292524; }
.chart-container { position: relative; width: 100%; max-width: 600px; margin-left: auto; margin-right: auto; height: 300px; max-height: 400px; }
@media (min-width: 768px) { .chart-container { height: 350px; } }
.node-card { transition: all 0.3s ease; border: 1px solid #e7e5e4; }
.node-card:hover { transform: translateY(-2px); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); border-color: #a8a29e; }
.agent-card { cursor: pointer; transition: background-color 0.2s ease; }
.agent-card.active { background-color: #f5f5f4; border-left: 4px solid #44403c; }
</style>
</head>
<body class="bg-stone-50 text-stone-800 antialiased selection:bg-stone-300">

<!-- Chosen Palette: Warm Neutral & Slate -->
<!-- Application Structure Plan: Dashboard approach prioritizing operational layers. Chosen for usability because the Epyon architecture is highly segmented (Local, Shared, Frontier) with distinct agent roles. A unified dashboard allows the user (Captain/COO) to quickly assess fleet distribution, system boundaries, and active friction points without navigating away from the single pane of glass. -->
<!-- Visualization & Content Choices: Fleet Distribution -> Proportions -> Chart.js Doughnut -> Hover tooltips -> Standard library, clean presentation. System Architecture -> Organization -> Interactive HTML/CSS Grid -> Click for details -> NO SVG, highly responsive. Friction Points -> Inform -> Dynamic Text Blocks -> Click to toggle -> Clear textual synthesis. -->
<!-- CONFIRMATION: NO SVG graphics used. NO Mermaid JS used. -->

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    
    <header class="mb-12 border-b border-stone-200 pb-6">
        <h1 class="text-4xl font-bold tracking-tight text-stone-900 mb-2">Epyon Fleet Operations</h1>
        <p class="text-lg text-stone-500">Chief Systems Architect & COO Overview (EUL-9)</p>
    </header>

    <section id="fleet-overview" class="mb-16">
        <div class="mb-6">
            <h2 class="text-2xl font-semibold mb-2">Fleet Deployment & Agent Roster</h2>
            <p class="text-stone-600 leading-relaxed">This section provides a real-time overview of the active agent crew and their deployment environments. Understanding where our agents operate is critical for managing coordination overhead and ensuring the right intelligence is applied to the appropriate layer of the stack. Interact with the roster to view specific agent directives and handover protocols.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="bg-white p-6 rounded-xl shadow-sm border border-stone-100 flex flex-col">
                <h3 class="text-lg font-semibold mb-4 text-center">Deployment Distribution</h3>
                <div class="chart-container flex-grow">
                    <canvas id="deploymentChart"></canvas>
                </div>
            </div>

            <div class="lg:col-span-2 bg-white p-6 rounded-xl shadow-sm border border-stone-100 grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <h3 class="text-lg font-semibold mb-4 border-b border-stone-100 pb-2">Active Roster</h3>
                    <ul id="agent-list" class="space-y-2 max-h-[300px] overflow-y-auto pr-2">
                    </ul>
                </div>
                <div class="bg-stone-50 p-4 rounded-lg border border-stone-200">
                    <h3 class="text-sm font-bold text-stone-400 uppercase tracking-wider mb-2">Agent Details</h3>
                    <div id="agent-details">
                        <p class="text-stone-500 italic text-sm mt-10 text-center">Select an agent from the roster to view operational details and protocols.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="integration-map" class="mb-16">
        <div class="mb-6">
            <h2 class="text-2xl font-semibold mb-2">Systems Integration Architecture</h2>
            <p class="text-stone-600 leading-relaxed">This architecture map visualizes the Epyon's operational environments and the data bridges connecting them. As we shift from isolated planning to automated execution, visualizing the friction points at system boundaries is the primary objective of the COO. Click on any architectural node to inspect its current state and operational purpose.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
            <div class="lg:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-4">
                
                <div class="bg-white rounded-xl shadow-sm border border-stone-200 p-5 flex flex-col">
                    <div class="mb-4 pb-2 border-b border-stone-100">
                        <span class="text-xs font-bold text-stone-400 uppercase tracking-wider">Layer 1</span>
                        <h4 class="text-lg font-semibold">The Local Node</h4>
                    </div>
                    <div class="space-y-3 flex-grow">
                        <div class="node-card p-3 rounded-lg bg-stone-50 cursor-pointer" onclick="updateNodeDetails('machine1')">
                            <span class="font-semibold block">Machine 1 (Windows)</span>
                            <span class="text-xs text-stone-500">Captain's Deck & Planning</span>
                        </div>
                        <div class="node-card p-3 rounded-lg bg-stone-50 cursor-pointer" onclick="updateNodeDetails('machine2')">
                            <span class="font-semibold block">Machine 2 (Ubuntu)</span>
                            <span class="text-xs text-stone-500">The Workhorse (Node, Docker)</span>
                        </div>
                        <div class="node-card p-3 rounded-lg border-dashed border-2 border-stone-300 cursor-pointer" onclick="updateNodeDetails('tailnet')">
                            <span class="font-semibold block">Tailscale Mesh</span>
                            <span class="text-xs text-stone-500">Private connectivity</span>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow-sm border border-stone-200 p-5 flex flex-col">
                    <div class="mb-4 pb-2 border-b border-stone-100">
                        <span class="text-xs font-bold text-stone-400 uppercase tracking-wider">Layer 2</span>
                        <h4 class="text-lg font-semibold">Shared Intelligence</h4>
                    </div>
                    <div class="space-y-3 flex-grow">
                        <div class="node-card p-3 rounded-lg bg-stone-50 cursor-pointer" onclick="updateNodeDetails('neo4j')">
                            <span class="font-semibold block">Neo4j AuraDB</span>
                            <span class="text-xs text-stone-500">Graph relations & context</span>
                        </div>
                        <div class="node-card p-3 rounded-lg bg-stone-50 cursor-pointer" onclick="updateNodeDetails('mongo')">
                            <span class="font-semibold block">MongoDB / Vercel</span>
                            <span class="text-xs text-stone-500">Flat operational data</span>
                        </div>
                        <div class="node-card p-3 rounded-lg bg-stone-800 text-stone-100 cursor-pointer" onclick="updateNodeDetails('mcp')">
                            <span class="font-semibold block">Epyon MCP Server</span>
                            <span class="text-xs text-stone-300">Durable control plane</span>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow-sm border border-stone-200 p-5 flex flex-col">
                    <div class="mb-4 pb-2 border-b border-stone-100">
                        <span class="text-xs font-bold text-stone-400 uppercase tracking-wider">Layer 3</span>
                        <h4 class="text-lg font-semibold">Microsoft Frontier</h4>
                    </div>
                    <div class="space-y-3 flex-grow">
                        <div class="node-card p-3 rounded-lg bg-stone-50 cursor-pointer" onclick="updateNodeDetails('unlimited')">
                            <span class="font-semibold block">Epyon Unlimited</span>
                            <span class="text-xs text-stone-500">Production Tenant</span>
                        </div>
                        <div class="node-card p-3 rounded-lg bg-stone-50 cursor-pointer" onclick="updateNodeDetails('eaiu')">
                            <span class="font-semibold block">EAIU</span>
                            <span class="text-xs text-stone-500">Secondary / Education</span>
                        </div>
                        <div class="node-card p-3 rounded-lg bg-stone-50 cursor-pointer" onclick="updateNodeDetails('azure')">
                            <span class="font-semibold block">Azure Backbone</span>
                            <span class="text-xs text-stone-500">Durable storage lakes</span>
                        </div>
                    </div>
                </div>

            </div>

            <div class="bg-stone-800 text-stone-100 p-6 rounded-xl shadow-sm">
                <h3 class="text-lg font-semibold mb-4 border-b border-stone-600 pb-2">Node Telemetry</h3>
                <div id="node-details">
                    <p class="text-stone-400 italic text-sm mt-4">Select an architectural node from the map to view systems context.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="friction-log">
        <div class="mb-6">
            <h2 class="text-2xl font-semibold mb-2">COO Log: Systemic Friction Points</h2>
            <p class="text-stone-600 leading-relaxed">Continuous observation of the Epyon machine running reveals areas where performance degrades. This section documents active friction points identified in recent cycles. Addressing these is the priority for the architectural and engineering tiers to ensure seamless multimodal intelligence routing.</p>
        </div>

        <div class="space-y-4" id="friction-list">
        </div>
    </section>

</div>

<script>
const agentData = [
    { id: 'eul9', name: 'Strategic First Mate', designation: 'EUL-9', role: 'Chief Systems Architect & COO', focus: 'Cross-platform integration, MCP, Broad-spectrum reasoning', handoff: 'Architectural PRs -> Keelforge/Ironbeard' },
    { id: 'eul6', name: 'Volta', designation: 'EUL-6', role: 'Async Review & Standards', focus: 'Microsoft Operating Manual, Routing decisions', handoff: 'Standardization -> Agent 365' },
    { id: 'eul20', name: 'Keelforge', designation: 'EUL-20', role: 'Engine Room Architect', focus: 'Legend MCP implementation, Azure/Entra identity flows', handoff: 'Tactical execution via EUL-9 review' },
    { id: 'eul3', name: 'Tempus Vale', designation: 'EUL-3', role: 'Navigation & Documentation', focus: 'Charting navigation systems, architectural "why" documentation', handoff: 'Knowledge base updates' },
    { id: 'eul80', name: 'Admiral Quatra', designation: 'EUL-80', role: 'Fleet Coordinator', focus: 'Fleet coordination & Scheduling', handoff: 'Strategic scheduling' },
    { id: 'eul16', name: 'Captain Campbell', designation: 'EUL-16', role: 'Command', focus: 'Final approval, human-in-the-loop decisions', handoff: 'Ultimate authority' },
    { id: 'eul4', name: 'Ironbeard', designation: 'EUL-4', role: 'Tactical Engineer', focus: 'Bounded fixes, deep implementation', handoff: 'Execution of architectural plans' }
];

const deploymentStats = {
    labels: ['Local Nodes', 'Cloud Frontier', 'MCP / Shared', 'Mobile / Edge'],
    data: [30, 45, 15, 10]
};

const nodeData = {
    'machine1': { title: 'Machine 1 (Windows)', status: 'Active', desc: 'Primary planning and high-level execution surface. Hosts VS Insiders, Claude Desktop, ChatGPT, and Notion.' },
    'machine2': { title: 'Machine 2 (Ubuntu Server)', status: 'Active', desc: 'The workhorse. Runs Node, Docker, Claude Code CLI, and crucial MCP server dependencies.' },
    'tailnet': { title: 'Tailscale (Tailnet)', status: 'Monitored (PATCH-01)', desc: 'The private mesh connecting Machine 1, Machine 2, and mobile endpoints (Cowork/Dispatch).' },
    'neo4j': { title: 'Neo4j AuraDB', status: 'Active', desc: 'Layer 2 of the Claude Brain architecture. Handles relationship traversal, session context, and citation graphs for Zero/Atlas.' },
    'mongo': { title: 'MongoDB / Vercel', status: 'Active', desc: 'Handles flat operational data and primary web application hosting layers.' },
    'mcp': { title: 'Epyon MCP Server', status: 'Critical', desc: 'The primary Cr3w coordination channel and durable control plane connecting local nodes to AI models.' },
    'unlimited': { title: 'Epyon Unlimited', status: 'Production', desc: 'Where Agent 365, Project Opal, and governed Microsoft 365 workflows live.' },
    'eaiu': { title: 'EAIU Tenant', status: 'Validation', desc: 'Secondary validation track for Pathfinder and educational operations.' },
    'azure': { title: 'Azure Backbone', status: 'Target State', desc: 'Landing zones, Key Vaults, Container Apps. The target state for robust, enterprise-grade deployment.' }
};

const frictionData = [
    { title: 'Coordination Overhead', status: 'Monitoring', desc: 'The shift from Notion-based planning (Clearwater/Volta) to automated M365 execution requires rigorous handoff protocols. We cannot afford agents working in silos (e.g., Keelforge operating without pushing outputs to the crew).' },
    { title: 'Identity & Governance', status: 'Active Build', desc: 'Delineating between Volta@epyon-unlimited.com, KeelForge@epyon-unlimited.com, and the Captain\'s authority within Entra ID.' },
    { title: 'Database Migration', status: 'Pending', desc: 'Moving graph-native data relationships from PostgreSQL/Supabase legacy systems fully into Neo4j while keeping operational data flat in MongoDB.' }
];

function initDashboard() {
    const ctx = document.getElementById('deploymentChart').getContext('2d');
    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: deploymentStats.labels,
            datasets: [{
                data: deploymentStats.data,
                backgroundColor: ['#a8a29e', '#57534e', '#d6d3d1', '#78716c'],
                borderWidth: 0,
                hoverOffset: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom', labels: { font: { family: 'Inter' } } },
                tooltip: { backgroundColor: '#292524', titleFont: { family: 'Inter' }, bodyFont: { family: 'Inter' } }
            },
            cutout: '70%'
        }
    });

    const agentList = document.getElementById('agent-list');
    agentData.forEach(agent => {
        const li = document.createElement('li');
        li.className = 'agent-card p-3 rounded-lg border border-transparent hover:border-stone-200 text-sm';
        li.innerHTML = `<span class="font-bold block">${agent.name}</span><span class="text-stone-500 text-xs">${agent.designation} - ${agent.role}</span>`;
        li.onclick = () => {
            document.querySelectorAll('.agent-card').forEach(el => el.classList.remove('active'));
            li.classList.add('active');
            document.getElementById('agent-details').innerHTML = `
                <div class="mb-3"><span class="text-xs text-stone-500 block uppercase">Role</span><span class="font-semibold text-stone-800">${agent.role}</span></div>
                <div class="mb-3"><span class="text-xs text-stone-500 block uppercase">Primary Focus</span><span class="text-stone-700">${agent.focus}</span></div>
                <div><span class="text-xs text-stone-500 block uppercase">Protocol</span><span class="text-stone-700 text-sm bg-stone-200 px-2 py-1 rounded inline-block mt-1">${agent.handoff}</span></div>
            `;
        };
        agentList.appendChild(li);
    });

    const frictionContainer = document.getElementById('friction-list');
    frictionData.forEach(f => {
        const div = document.createElement('div');
        div.className = 'bg-white border border-stone-200 rounded-lg p-5 shadow-sm';
        let statusColor = f.status === 'Monitoring' ? 'bg-amber-100 text-amber-800' : (f.status === 'Active Build' ? 'bg-emerald-100 text-emerald-800' : 'bg-stone-200 text-stone-800');
        div.innerHTML = `
            <div class="flex justify-between items-start mb-2">
                <h3 class="font-semibold text-lg">${f.title}</h3>
                <span class="text-xs font-bold px-2 py-1 rounded uppercase tracking-wide ${statusColor}">${f.status}</span>
            </div>
            <p class="text-stone-600 text-sm leading-relaxed">${f.desc}</p>
        `;
        frictionContainer.appendChild(div);
    });
}

function updateNodeDetails(nodeId) {
    const data = nodeData[nodeId];
    if(!data) return;
    const container = document.getElementById('node-details');
    container.innerHTML = `
        <h4 class="text-xl font-bold text-white mb-1">${data.title}</h4>
        <span class="inline-block px-2 py-1 bg-stone-700 text-stone-300 text-xs rounded mb-4">${data.status}</span>
        <p class="text-stone-300 text-sm leading-relaxed">${data.desc}</p>
    `;
}

window.onload = initDashboard;
</script>
</body>
</html>
